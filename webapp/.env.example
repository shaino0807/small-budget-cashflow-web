CUSTOMER_DATA_KEY=請填入至少32字元的隨機密鑰
ACCESS_CODE_PEPPER=請填入至少24字元的隨機密鑰
ADMIN_API_KEY=請填入至少24字元的管理金鑰
CUSTOMER_DATA_DIR=./webapp/private-data
CUSTOMER_RETENTION_DAYS=365
LINE_LEDGER_RETENTION_DAYS=1095
MARKET_REFRESH_MINUTES=15
ACTION_DISPATCH_MINUTES=15
GITHUB_ACTIONS_TOKEN=只放在後臺環境變數且需具備workflow權限
GITHUB_REPOSITORY=shaino0807/small-budget-cashflow-web
GITHUB_WORKFLOW_FILE=pages.yml
GITHUB_WORKFLOW_REF=main
ALLOWED_ORIGINS=http://localhost:5188,https://small-budget-cashflow-api.onrender.com,https://shaino0807.github.io
SITE_PUBLIC_BASE_URL=https://small-budget-cashflow-api.onrender.com
API_PUBLIC_BASE_URL=https://small-budget-cashflow-api.onrender.com
AUTH_SESSION_DAYS=30
LINE_LOGIN_CHANNEL_ID=請填 LINE Login channel ID
LINE_LOGIN_CHANNEL_SECRET=請填 LINE Login channel secret
LINE_LOGIN_CALLBACK_URL=https://small-budget-cashflow-api.onrender.com/api/auth/line/callback
LINE_LIFF_ID=請填 LIFF ID
LINE_LIFF_URL=https://liff.line.me/你的LIFF_ID
ECPAY_ENV=stage
# Stage 測試可先使用綠界公開測試參數；正式上線請改 0 並填入正式 MerchantID / HashKey / HashIV。
ECPAY_USE_STAGE_DEFAULTS=1
ECPAY_MERCHANT_ID=your-ecpay-merchant-id
ECPAY_HASH_KEY=your-ecpay-hash-key
ECPAY_HASH_IV=your-ecpay-hash-iv
FULL_REPORT_PRICE_TWD=499
CONSULTATION_DEPOSIT_TWD=200
CONSULTATION_FEE_TWD=1500
CONSULTATION_IG_URL=https://www.instagram.com/chendino080077/
CONSULTATION_LINE_URL=https://lin.ee/your-line-official-account
LINE_CHANNEL_SECRET=請填 LINE Developers Messaging API 的 Channel secret
LINE_CHANNEL_ACCESS_TOKEN=請填 LINE Developers Messaging API 的 Channel access token
# 本地測試可設 1 避免真的呼叫 LINE reply API；正式部署請移除或設 0。
LINE_REPLY_DISABLED=0
# Render 啟動時建立或重用預設 Rich Menu，不會把 token 寫進 Git。
LINE_RICH_MENU_AUTO_DEPLOY=1
LINE_RICH_MENU_VERSION=v3
# 規則解析優先；只有規則看不懂或一句含多筆時才呼叫 OpenAI。
LINE_AI_PARSER_ENABLED=1
OPENAI_API_KEY=只放在Render環境變數
OPENAI_LINE_PARSER_MODEL=gpt-5.4-nano
